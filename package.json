    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.8.22",
    "@vitejs/plugin-react": "^6.0.2",
    "oxlint": "^1.69.0",
    "playwright": "^1.61.1",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "vercel": "^54.18.6",
    "vite": "^8.1.0"
  }
