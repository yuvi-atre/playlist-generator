# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# From your Spotify app dashboard (Settings → Client ID)
# Safe to expose — PKCE doesn't use a client secret.
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Optional — defaults to http://127.0.0.1:5173/callback for local dev.
# Must exactly match the redirect URI registered in your Spotify app dashboard.
# VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/callback

# Anthropic API key — backend only, NO VITE_ prefix (never expose to the browser)
ANTHROPIC_API_KEY=sk-ant-...
